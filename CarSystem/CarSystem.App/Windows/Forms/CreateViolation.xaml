<Controls:MetroWindow x:Name="CreateViolationWindow" x:Class="CarSystem.App.Windows.Forms.CreateViolation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarSystem.App.Windows.Forms"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        mc:Ignorable="d"
        Title="Създаване на нов запис" Height="500" Width="720"
        GlowBrush="#9B2335" BorderBrush="#9B2335"
        Background="#EEF1F5"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Хедър -->
        <Border Grid.Row="0" Background="#9B2335">
            <TextBlock Text="ДОБАВЯНЕ НА НОВО НАРУШЕНИЕ"
                       Foreground="White" FontSize="15" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Форма -->
        <Border Grid.Row="1" Background="White" Margin="12,12,12,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.13" Color="#000000"/>
            </Border.Effect>
            <Grid Margin="20,16,20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- лице / глоба -->
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>  <!-- автомобил / дата -->
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>  <!-- нарушение / цена+номер -->
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1"/>     <!-- разделител -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="36"/>    <!-- бутони -->
                </Grid.RowDefinitions>

                <!-- Ред 1, Ляво: Лице -->
                <StackPanel x:Name="PersonPickerPanel" Grid.Row="0" Grid.Column="0">
                    <Label x:Name="PersonPickerLabel" Content="Изберете потребител:"
                           Style="{StaticResource FormLabel}"/>
                    <Controls:SplitButton x:Name="PersonPickerButton"
                           DisplayMemberPath="DisplayName" Height="32"
                           SelectionChanged="PersonPickerButton_SelectionChanged"/>
                </StackPanel>

                <!-- Ред 1, Дясно: Глоба -->
                <StackPanel x:Name="FinePickerPanel" Grid.Row="0" Grid.Column="2" Visibility="Hidden">
                    <Label x:Name="FinePickerLabel" Content="Изберете вид глоба:"
                           Style="{StaticResource FormLabel}"/>
                    <Controls:SplitButton x:Name="FinePickerButton"
                           DisplayMemberPath="Violation" Height="32"
                           SelectionChanged="FinePickerButton_SelectionChanged"/>
                </StackPanel>

                <!-- Ред 2, Ляво: Автомобил -->
                <StackPanel x:Name="CarPickerPanel" Grid.Row="2" Grid.Column="0" Visibility="Hidden">
                    <Label x:Name="CarPickerLabel" Content="Изберете превозно средство:"
                           Style="{StaticResource FormLabel}"/>
                    <Controls:SplitButton x:Name="CarPickerButton"
                           DisplayMemberPath="DisplayName" Height="32"
                           SelectionChanged="CarPickerButton_SelectionChanged"/>
                </StackPanel>

                <!-- Ред 2, Дясно: Дата -->
                <StackPanel x:Name="LicenceBackOnDatePickerPanel" Grid.Row="2" Grid.Column="2" Visibility="Hidden">
                    <Label x:Name="LicenceBackOnDatePickerLabel" Content="Дата на връщане на СУМПС:"
                           Style="{StaticResource FormLabel}"/>
                    <DatePicker x:Name="LicenceBackOnDatePicker" Height="36"
                           SelectedDateChanged="LicenceBackOnDatePicker_SelectedDateChanged"/>
                </StackPanel>

                <!-- Ред 3, Ляво: Нарушение -->
                <StackPanel x:Name="ViolationPickerPanel" Grid.Row="4" Grid.Column="0" Visibility="Hidden">
                    <Label x:Name="ViolationPickerLabel" Content="Изберете вид нарушение:"
                           Style="{StaticResource FormLabel}"/>
                    <Controls:SplitButton x:Name="ViolationPickerButton"
                           DisplayMemberPath="Message" Height="32"
                           SelectionChanged="ViolationPickerButton_SelectionChanged"/>
                </StackPanel>

                <!-- Ред 3, Дясно: Сума и Номер фиш -->
                <Grid x:Name="FinePriceFineNumberPanel" Grid.Row="4" Grid.Column="2" Visibility="Hidden">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label x:Name="FinePriceLabel" Content="Сума (€):"
                               Style="{StaticResource FormLabel}"/>
                        <Controls:NumericUpDown x:Name="FinePriceNumericUpDown"
                               Minimum="0" Maximum="10000" Height="30"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label x:Name="FineNumberLabel" Content="№ Фиш / Акт:"
                               Style="{StaticResource FormLabel}"/>
                        <Controls:NumericUpDown x:Name="FineNumberNumericUpDown"
                               Minimum="0" Height="30"/>
                    </StackPanel>
                </Grid>

                <!-- Разделител -->
                <Rectangle Grid.Row="6" Grid.ColumnSpan="3" Fill="#E0E6EA"/>

                <!-- Бутони -->
                <Grid Grid.Row="8" Grid.ColumnSpan="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="CancelButton" Grid.Column="0"
                            Content="Отказ"
                            Style="{StaticResource NeutralButton}"
                            Click="CancelButton_Click"/>
                    <Button x:Name="ClearButton" Grid.Column="2"
                            Content="Изчисти полетата"
                            Style="{StaticResource NeutralButton}"
                            Click="ClearButton_Click" IsEnabled="False"/>
                    <Button x:Name="SaveButton" Grid.Column="4"
                            Content="Запиши"
                            Style="{StaticResource SuccessButton}"
                            Click="SaveButton_Click" IsEnabled="False"/>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Controls:MetroWindow>
