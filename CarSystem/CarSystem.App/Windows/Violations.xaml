<Controls:MetroWindow x:Name="ViolationsWindow" x:Class="CarSystem.App.Windows.Violations"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarSystem.App.Windows"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        mc:Ignorable="d"
        Title="Нарушения" Height="720" Width="1280"
        GlowBrush="#1A2F4B" BorderBrush="#1A2F4B"
        Background="#EEF1F5"
        WindowStartupLocation="CenterScreen"
        Opacity="0">

    <Controls:MetroWindow.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Controls:MetroWindow.Triggers>

    <Controls:MetroWindow.Flyouts>
        <Controls:FlyoutsControl>
            <Controls:Flyout x:Name="HamburgerMenuFlyout"
                    Header="Опции" Position="Right" Width="300"
                    Background="#F4F6F8" Foreground="#1A2F4B"
                    Theme="Light" FontSize="14">
                <StackPanel Margin="16,12,16,0">
                    <Button x:Name="CreateButton"
                            Content="＋  Добави ново нарушение"
                            Height="50" FontSize="14"
                            Background="#154360" Foreground="White"
                            BorderBrush="#154360" Cursor="Hand"
                            Click="CreateButton_Click"/>
                </StackPanel>
            </Controls:Flyout>
        </Controls:FlyoutsControl>
    </Controls:MetroWindow.Flyouts>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Хедър -->
        <Border Grid.Row="0" Background="#1A2F4B">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button x:Name="PreviousButton"
                            Width="40" Height="40" Cursor="Hand"
                            ToolTip="Върни се към предишния екран"
                            Style="{DynamicResource MahApps.Metro.Styles.MetroCircleButtonStyle}"
                            BorderBrush="White" Margin="0,0,6,0"
                            Click="PreviousButton_Click">
                        <Image Source="/CarSystem.App;component/Images/Previous.png" Height="20" Width="18"/>
                    </Button>
                    <Button x:Name="HomeScreenButton"
                            Width="40" Height="40" Cursor="Hand"
                            ToolTip="Върни се към началния екран"
                            Style="{DynamicResource MahApps.Metro.Styles.MetroCircleButtonStyle}"
                            BorderBrush="White"
                            Click="HomeScreenButton_Click">
                        <Image Source="/CarSystem.App;component/Images/HomeScreen.png" Height="22" Width="20"/>
                    </Button>
                </StackPanel>

                <TextBlock Text="НАРУШЕНИЯ"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button x:Name="ViolationColumnChooserButton"
                            Width="40" Height="40" Cursor="Hand"
                            ToolTip="Покажи / скрий колони"
                            Style="{DynamicResource MahApps.Metro.Styles.MetroCircleButtonStyle}"
                            BorderBrush="White" Margin="0,0,6,0"
                            Click="ViolationColumnChooserButton_Click">
                        <Image Source="/CarSystem.App;component/Images/funnel.png" Height="18" Width="18"/>
                    </Button>
                    <Button x:Name="HamburgerMenuButton"
                            Width="40" Height="40" Cursor="Hand"
                            ToolTip="Допълнителни опции"
                            Style="{DynamicResource MahApps.Metro.Styles.MetroCircleButtonStyle}"
                            BorderBrush="White"
                            Click="HamburgerMenuButton_Click">
                        <Image Source="/CarSystem.App;component/Images/HamburgerMenu.png" Height="18" Width="18"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Popup x:Name="ViolationColumnChooserPopup"
               PlacementTarget="{Binding ElementName=ViolationColumnChooserButton}"
               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                    Padding="12,8,12,10" MinWidth="180">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Видими колони" FontWeight="Bold" FontSize="12"
                               Foreground="#1A2F4B" Margin="0,0,0,6"/>
                    <ItemsControl x:Name="ViolationColumnChooserList"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Съдържание -->
        <Grid Grid.Row="1" Margin="12,12,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Карта с филтри -->
            <Border Grid.Row="0" Background="White" Padding="14,12,14,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.13" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Филтри за търсене"
                               FontSize="13" FontWeight="Bold" Foreground="#1A2F4B"
                               Margin="0,0,0,10"/>

                    <!-- Полета за филтриране -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label x:Name="CardIdLabel" Content="№ Лична карта:"
                                   Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="CardIdTextBox" Height="28"
                                     Controls:TextBoxHelper.ClearTextButton="True"
                                     Controls:TextBoxHelper.Watermark="Въведи номер..."
                                     TextChanged="TextBoxChange"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label x:Name="VehicleNumberLabel" Content="№ Превозно средство:"
                                   Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="VehicleNumberTextBox" Height="28"
                                     Controls:TextBoxHelper.ClearTextButton="True"
                                     Controls:TextBoxHelper.Watermark="Въведи номер..."
                                     TextChanged="TextBoxChange"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <Label x:Name="EGNLabel" Content="ЕГН:"
                                   Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="EGNTextBox" Height="28"
                                     Controls:TextBoxHelper.ClearTextButton="True"
                                     Controls:TextBoxHelper.Watermark="Въведи ЕГН..."
                                     TextChanged="TextBoxChange"/>
                        </StackPanel>

                        <StackPanel Grid.Column="6">
                            <Label x:Name="FineNumberLabel" Content="№ Фиш:"
                                   Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="FineNumberTextBox" Height="28"
                                     Controls:TextBoxHelper.ClearTextButton="True"
                                     Controls:TextBoxHelper.Watermark="Въведи номер..."
                                     TextChanged="TextBoxChange"/>
                        </StackPanel>
                    </Grid>

                    <!-- Вид нарушение + бутони -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>

                        <Label x:Name="ViolationPickerLabel" Grid.Column="0"
                               Content="Вид нарушение:" Style="{StaticResource FormLabel}"
                               VerticalAlignment="Center" Margin="0,0,8,0" Padding="0"/>
                        <Controls:SplitButton x:Name="ViolationPickerButton" Grid.Column="1"
                               DisplayMemberPath="Message"
                               SelectionChanged="ViolationPickerButton_SelectionChanged"
                               Height="30"/>
                        <Button x:Name="FilterButton" Grid.Column="3"
                                Content="Филтрирай"
                                Background="#154360" Foreground="White"
                                BorderBrush="#154360" Height="30"
                                Cursor="Hand" IsEnabled="False"
                                Click="FilterButton_Click"/>
                        <Button x:Name="ClearFiltersButton" Grid.Column="5"
                                Content="Изчисти филтрите"
                                Background="#5D6D7E" Foreground="White"
                                BorderBrush="#5D6D7E" Height="30"
                                Cursor="Hand"
                                Click="ClearFiltersButton_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Таблица с нарушения -->
            <Border Grid.Row="2" Background="White">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.13" Color="#000000"/>
                </Border.Effect>
                <DataGrid x:Name="ViolationsDataGrid"
                          AutoGenerateColumns="True"
                          AutoGeneratingColumn="ViolationsDataGrid_AutoGeneratingColumn"
                          CanUserAddRows="False"
                          CanUserResizeColumns="False"
                          CanUserSortColumns="True"
                          ColumnWidth="*" RowHeight="36"
                          Cursor="Hand"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          EnableRowVirtualization="True"
                          PreviewMouseRightButtonDown="DisableContextMenuOnDgHeaders_PreviewMouseRightButtonDown">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Изтрий" Click="DeleteItem_Click" Cursor="Hand"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Controls:MetroWindow>
