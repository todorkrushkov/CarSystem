<Controls:MetroWindow x:Name="ReferencesWindow" x:Class="CarSystem.App.Windows.References"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:local="clr-namespace:CarSystem.App.Windows"
        mc:Ignorable="d"
        Title="Справки" Height="720" Width="640"
        GlowBrush="#1A2F4B" BorderBrush="#1A2F4B"
        Background="#EEF1F5"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Opacity="0">

    <Controls:MetroWindow.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Controls:MetroWindow.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Хедър -->
        <Border Grid.Row="0" Background="#1A2F4B">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button x:Name="PreviousButton"
                            Width="40" Height="40" Cursor="Hand"
                            ToolTip="Върни се към предишния екран"
                            Style="{DynamicResource MahApps.Metro.Styles.MetroCircleButtonStyle}"
                            BorderBrush="White" Margin="0,0,6,0"
                            Click="PreviousButton_Click">
                        <Image Source="/CarSystem.App;component/Images/Previous.png" Height="20" Width="18"/>
                    </Button>
                    <Button x:Name="HomeScreenButton"
                            Width="40" Height="40" Cursor="Hand"
                            ToolTip="Върни се към началния екран"
                            Style="{DynamicResource MahApps.Metro.Styles.MetroCircleButtonStyle}"
                            BorderBrush="White"
                            Click="HomeScreenButton_Click">
                        <Image Source="/CarSystem.App;component/Images/HomeScreen.png" Height="22" Width="20"/>
                    </Button>
                </StackPanel>
                <TextBlock Text="СПРАВКИ"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Съдържание -->
        <Border Grid.Row="1" Background="White" Margin="12,12,12,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.13" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#EEF1F5" Padding="14,10,14,10">
                    <TextBlock Text="Изберете вид справка за генериране на PDF документ"
                               FontSize="13" Foreground="#1A2F4B" FontWeight="SemiBold"/>
                </Border>

                <TabControl Name="ReferencesTabControl" Grid.Row="1" Margin="0">

                    <!-- По лице -->
                    <TabItem Name="PeopleTabItem" Header="По лице"
                             Background="#EEF1F5"
                             Selector.Selected="PeopleTabItem_Selected">
                        <Grid Background="White" Margin="16,14,16,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label x:Name="PersonPickerLabel" Grid.Row="0"
                                   Content="Изберете лице за справка:"
                                   FontSize="13" Foreground="#5D6D7E" Padding="0"/>
                            <Controls:SplitButton x:Name="PersonPickerButton" Grid.Row="2"
                                   DisplayMemberPath="DisplayName"
                                   SelectionChanged="PersonPickerButton_SelectionChanged"
                                   Height="32"/>
                            <Border Grid.Row="4" Background="#EEF1F5" Padding="10,8,10,8"
                                    Margin="0,12,0,0"
                                    Visibility="{Binding ElementName=PersonPdfDownloadImage, Path=Visibility}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Name="PersonPdfDownloadImage"
                                           Source="/CarSystem.App;component/Images/Pdf.png"
                                           Height="60" Width="120" Cursor="Hand"
                                           VerticalAlignment="Center"
                                           PreviewMouseLeftButtonDown="PersonPdfDownloadImage_PreviewMouseLeftButtonDown"
                                           Visibility="Hidden"/>
                                    <TextBlock Text="Кликни за изтегляне на справката"
                                               FontSize="16" Foreground="#1A5276"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Visibility="{Binding ElementName=PersonPdfDownloadImage, Path=Visibility}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- По превозно средство -->
                    <TabItem Name="CarsTabItem" Header="По превозно средство"
                             Background="#EEF1F5"
                             Selector.Selected="CarsTabItem_Selected">
                        <Grid Background="White" Margin="16,14,16,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label x:Name="CarPickerLabel" Grid.Row="0"
                                   Content="Изберете превозно средство за справка:"
                                   FontSize="13" Foreground="#5D6D7E" Padding="0"/>
                            <Controls:SplitButton x:Name="CarPickerButton" Grid.Row="2"
                                   DisplayMemberPath="DisplayName"
                                   SelectionChanged="CarPickerButton_SelectionChanged"
                                   Height="32"/>
                            <Border Grid.Row="4" Background="#EEF1F5" Padding="10,8,10,8"
                                    Margin="0,12,0,0"
                                    Visibility="{Binding ElementName=CarPdfDownloadImage, Path=Visibility}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Name="CarPdfDownloadImage"
                                           Source="/CarSystem.App;component/Images/Pdf.png"
                                           Height="60" Width="120" Cursor="Hand"
                                           VerticalAlignment="Center"
                                           PreviewMouseLeftButtonDown="CarPdfDownloadImage_PreviewMouseLeftButtonDown"
                                           Visibility="Hidden"/>
                                    <TextBlock Text="Кликни за изтегляне на справката"
                                               FontSize="16" Foreground="#1A5276"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Visibility="{Binding ElementName=CarPdfDownloadImage, Path=Visibility}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>


                    <!-- Преглед на данни (генериран интерфейс) -->
                    <TabItem Name="BrowseTabItem" Header="Преглед на данни"
                             Background="#EEF1F5">
                        <Grid Background="White" Margin="16,14,16,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Избери вид данни за преглед — интерфейсът се генерира автоматично от обектите:"
                                       FontSize="13" Foreground="#5D6D7E" TextWrapping="Wrap"/>

                            <Button x:Name="BrowsePeopleButton" Grid.Row="2"
                                    Content="Преглед на всички лица"
                                    Height="46" FontSize="14" Cursor="Hand"
                                    Background="#1A2F4B" Foreground="White"
                                    BorderBrush="#1A2F4B"
                                    Click="BrowsePeopleButton_Click"/>

                            <Button x:Name="BrowseCarsButton" Grid.Row="4"
                                    Content="Преглед на всички автомобили"
                                    Height="46" FontSize="14" Cursor="Hand"
                                    Background="#154360" Foreground="White"
                                    BorderBrush="#154360"
                                    Click="BrowseCarsButton_Click"/>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Grid>
        </Border>
    </Grid>
</Controls:MetroWindow>
