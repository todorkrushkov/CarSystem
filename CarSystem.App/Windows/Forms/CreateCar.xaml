<Controls:MetroWindow x:Name="CreateCarWindow" x:Class="CarSystem.App.Windows.Forms.CreateCar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarSystem.App.Windows.Forms"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        mc:Ignorable="d"
        Title="Регистриране на ново превозно средство" Height="460" Width="640"
        GlowBrush="#145A32" BorderBrush="#145A32"
        Background="#EEF1F5"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Хедър -->
        <Border Grid.Row="0" Background="#145A32">
            <TextBlock Text="РЕГИСТРИРАНЕ НА НОВ АВТОМОБИЛ"
                       Foreground="White" FontSize="15" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Форма -->
        <Border Grid.Row="1" Background="White" Margin="12,12,12,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.13" Color="#000000"/>
            </Border.Effect>
            <StackPanel Margin="20,16,20,16">

                <!-- Ред 1: Марка / Модел -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label x:Name="BrandLabel" Content="Марка:"
                               Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="BrandTextBox" Height="30"
                                 Controls:TextBoxHelper.ClearTextButton="True"
                                 Controls:TextBoxHelper.Watermark="Въведи марка"
                                 TextChanged="TextBoxChange"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label x:Name="ModelLabel" Content="Модел:"
                               Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="ModelTextBox" Height="30"
                                 Controls:TextBoxHelper.ClearTextButton="True"
                                 Controls:TextBoxHelper.Watermark="Въведи модел"
                                 TextChanged="TextBoxChange"/>
                    </StackPanel>
                </Grid>

                <!-- Ред 2: Конски сили / Брой места -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label x:Name="EnginePowerLabel" Content="Конски сили:"
                               Style="{StaticResource FormLabel}"/>
                        <Controls:NumericUpDown x:Name="EnginePowerNumericUpDown"
                               Value="50" Minimum="50" Height="30"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label x:Name="PeopleCarryLabel" Content="Брой места:"
                               Style="{StaticResource FormLabel}"/>
                        <Controls:NumericUpDown x:Name="PeopleCarryNumericUpDown"
                               Value="3" Minimum="3" Height="30"/>
                    </StackPanel>
                </Grid>

                <!-- Ред 3: Гориво / Стандарт -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label x:Name="FuelPickerLabel" Content="Гориво:"
                               Style="{StaticResource FormLabel}"/>
                        <Controls:SplitButton x:Name="FuelPickerButton"
                               DisplayMemberPath="Name" Height="32"
                               SelectionChanged="FuelPickerButton_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label x:Name="EmissionStandartLabel" Content="Емисионен стандарт:"
                               Style="{StaticResource FormLabel}"/>
                        <Controls:SplitButton x:Name="EmissionStandartPickerButton"
                               DisplayMemberPath="Name" Height="32"
                               SelectionChanged="EmissionStandartPickerButton_SelectionChanged"/>
                    </StackPanel>
                </Grid>

                <!-- Ред 4: Тегло / Цвят / Номер -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label x:Name="WeightLabel" Content="Тегло (кг):"
                               Style="{StaticResource FormLabel}"/>
                        <Controls:NumericUpDown x:Name="WeightNumericUpDown"
                               Value="0" Minimum="0" Height="30"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label x:Name="ColorLabel" Content="Цвят:"
                               Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="ColorTextBox" Height="30"
                                 Controls:TextBoxHelper.ClearTextButton="True"
                                 Controls:TextBoxHelper.Watermark="Въведи цвят"
                                 TextChanged="TextBoxChange"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <Label x:Name="NumberLabel" Content="Регистрационен номер:"
                               Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="NumberTextBox" Height="30"
                                 Controls:TextBoxHelper.ClearTextButton="True"
                                 Controls:TextBoxHelper.Watermark="Въведи номер"
                                 TextChanged="TextBoxChange"/>
                    </StackPanel>
                </Grid>

                <!-- Разделител -->
                <Rectangle Height="1" Fill="#E0E6EA" Margin="0,14,0,10"/>

                <!-- Бутони -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="CancelButton" Grid.Column="0"
                            Content="Отказ"
                            Style="{StaticResource NeutralButton}"
                            Click="CancelButton_Click"/>
                    <Button x:Name="ClearButton" Grid.Column="2"
                            Content="Изчисти полетата"
                            Style="{StaticResource NeutralButton}"
                            Click="ClearButton_Click" IsEnabled="False"/>
                    <Button x:Name="SaveButton" Grid.Column="4"
                            Content="Запиши"
                            Style="{StaticResource SuccessButton}"
                            Click="SaveButton_Click" IsEnabled="False"/>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</Controls:MetroWindow>
