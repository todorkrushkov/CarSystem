<Controls:MetroWindow x:Class="CarSystem.App.Windows.GenericListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        mc:Ignorable="d"
        Title="Преглед на данни" Height="560" Width="900"
        GlowBrush="#1A2F4B" BorderBrush="#1A2F4B"
        Background="#EEF1F5"
        WindowStartupLocation="CenterScreen"
        Opacity="0">

    <Controls:MetroWindow.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.2">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Controls:MetroWindow.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A2F4B">
            <Grid>
                <TextBlock x:Name="WindowTitleBlock"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button x:Name="ColumnChooserButton"
                            Width="40" Height="40" Cursor="Hand"
                            ToolTip="Покажи / скрий колони"
                            Style="{DynamicResource MahApps.Metro.Styles.MetroCircleButtonStyle}"
                            BorderBrush="White" Margin="0,0,6,0"
                            Click="ColumnChooserButton_Click">
                        <Image Source="/CarSystem.App;component/Images/funnel.png" Height="18" Width="18"/>
                    </Button>
                    <Button Width="40" Height="40" Cursor="Hand"
                            ToolTip="Затвори"
                            Style="{DynamicResource MahApps.Metro.Styles.MetroCircleButtonStyle}"
                            BorderBrush="White"
                            Click="CloseButton_Click">
                        <TextBlock Text="✕" Foreground="White" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Popup x:Name="ColumnChooserPopup"
               PlacementTarget="{Binding ElementName=ColumnChooserButton}"
               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                    Padding="12,8,12,10" MinWidth="180">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Видими колони" FontWeight="Bold" FontSize="12"
                               Foreground="#1A2F4B" Margin="0,0,0,6"/>
                    <ItemsControl x:Name="ColumnChooserList"/>
                </StackPanel>
            </Border>
        </Popup>

        <Border Grid.Row="1" Background="White" Margin="12,12,12,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.13" Color="#000000"/>
            </Border.Effect>
            <DataGrid x:Name="GenericDataGrid"
                      AutoGenerateColumns="True"
                      AutoGeneratingColumn="GenericDataGrid_AutoGeneratingColumn"
                      CanUserAddRows="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      ColumnWidth="*"
                      RowHeight="36"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"/>
        </Border>
    </Grid>
</Controls:MetroWindow>
