<Controls:MetroWindow x:Name="StartupWindow" x:Class="CarSystem.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:local="clr-namespace:CarSystem.App"
        mc:Ignorable="d"
        Title="Начало" Height="720" Width="640"
        GlowBrush="#1A2F4B" BorderBrush="#1A2F4B"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Opacity="0">

    <Controls:MetroWindow.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Controls:MetroWindow.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="295"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hero / лого секция -->
        <Border Grid.Row="0" Background="#1A2F4B" Margin="0,0,0,235" Grid.RowSpan="2">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image x:Name="StartupImage"
                       Height="298" Width="256" Margin="0,0,0,14"
                       Source="Images/Startup.png" Stretch="Uniform"/>
                <TextBlock Text="Система за управление на автомобилни нарушения"
                           Foreground="#7F9DB5" FontSize="30"
                           HorizontalAlignment="Center" Margin="0,10,0,0"
                           TextWrapping="Wrap" TextAlignment="Center" Width="435" Height="87"/>
            </StackPanel>
        </Border>

        <!-- Долна секция -->
        <Border Grid.Row="1" Background="#EEF1F5" Margin="0,174,0,0">
            <StackPanel Margin="10,0,10,0" VerticalAlignment="Center">
                <TextBlock Text="Добре дошли в системата"
                           FontSize="32" FontWeight="Bold" Foreground="#1A2F4B"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="Управлявайте нарушения, регистрации и справки от едно място."
                           FontSize="20" Foreground="#607080"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,22" Width="603"/>
                <Button x:Name="StartupButton"
                        Content="КЪМ МЕНЮТО"
                        Height="64" FontSize="24" FontWeight="Bold"
                        Background="#1A2F4B" Foreground="White"
                        BorderBrush="#1A2F4B" Cursor="Hand"
                        Click="StartupButton_Click" Width="361" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform AngleY="0.21"/>
                            <RotateTransform/>
                            <TranslateTransform Y="0.663"/>
                        </TransformGroup>
                    </Button.RenderTransform>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Controls:MetroWindow>
